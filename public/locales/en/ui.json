  "ending": {
    "liberation": {
      "title": "Liberation",
      "text": "The Vael dissolves into light, carrying secrets older than the island itself. You stand at the lighthouse top as the mechanism goes quiet. The sea is calm. You are free."
    },
    "keeper_peace": {
      "title": "The Keeper's Peace",
      "text": "You understand the bargain now. The island needs a keeper, and you choose to stay. Not trapped — chosen. The light burns steady through the night."
    },
    "sacrifice": {
      "title": "The Sacrifice",
      "text": "You feed yourself to the mechanism. The lighthouse burns brighter than it has in a century. The ships will be safe. Your name will not be remembered."
    },
    "corruption": {
      "title": "Corruption",
      "text": "You reach for power you do not understand. The island takes what it is owed. The lighthouse burns — but now something else looks through the lens."
    },
    "transcendence": {
      "title": "Transcendence",
      "text": "All seven truths cohere. You see the lighthouse for what it is: a lock, a key, and a door. You step through. The island watches you go with something like relief."
    }
  }
